# ResourceFlow - Production Environment (Hostinger VPS)
# Copy this to .env on your VPS and replace all placeholders
# NEVER commit .env to version control

APP_NAME=ResourceFlow
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://api.yourdomain.com

# Frontend URL - Required for Paystack callback, CORS, and Sanctum
FRONTEND_URL=https://yourdomain.com

# Sanctum - Frontend domain(s) for SPA cookie auth (comma-separated)
SANCTUM_STATEFUL_DOMAINS=yourdomain.com,www.yourdomain.com

LOG_CHANNEL=stack
LOG_LEVEL=warning

# Database - PostgreSQL (use dedicated user for production)
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=resourceflow
DB_USERNAME=resourceflow_user
DB_PASSWORD=your_secure_password

BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
SESSION_DRIVER=file
SESSION_LIFETIME=120

# Mail - Use Hostinger SMTP or your provider
MAIL_MAILER=smtp
MAIL_HOST=smtp.hostinger.com
MAIL_PORT=587
MAIL_USERNAME=noreply@yourdomain.com
MAIL_PASSWORD=your_mail_password
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="noreply@yourdomain.com"
MAIL_FROM_NAME="${APP_NAME}"

# Paystack - LIVE keys for production
PAYSTACK_PUBLIC_KEY=pk_live_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
PAYSTACK_SECRET_KEY=sk_live_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# QoreID - Ghana Card verification (Live keys)
QOREID_CLIENT_ID=your_qoreid_client_id
QOREID_SECRET=your_qoreid_secret
# Workflow ID for image-based verification (Ghana Card + selfie)
QOREID_WORKFLOW_ID=your_workflow_id
# On Linux VPS, system CA bundle is used - leave empty or remove
# QOREID_CAINFO=
